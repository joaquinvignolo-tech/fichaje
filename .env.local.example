# Copiá estos valores desde tu proyecto en supabase.com > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://TUPROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY

# Coordenadas de tu negocio (las obtenés desde Google Maps)
NEXT_PUBLIC_NEGOCIO_LAT=-34.6037
NEXT_PUBLIC_NEGOCIO_LNG=-58.3816

# Radio permitido en metros para fichar
NEXT_PUBLIC_RADIO_METROS=150
